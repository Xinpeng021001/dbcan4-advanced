// dbCAN4-advanced pipeline configuration
// -------------------------------------------------------------------------
manifest {
    name            = 'dbcan4-advanced'
    author          = 'dbCAN4-advanced'
    description     = 'Advanced fungal-protein CAZyme annotation (ESM-C + structure) publishing the BioForge standard output contract'
    version         = '0.1.0'
    nextflowVersion = '>=23.10.0'
    mainScript      = 'main.nf'
}

params {
    help              = false
    // --- I/O ---
    input             = null                      // samplesheet.csv: sample,faa
    outdir            = 'results'
    // --- release metadata (flows into manifest.json → BioForge Release) ---
    release_label     = "advanced-${new java.text.SimpleDateFormat('yyyy-MM-dd').format(new Date())}"
    pipeline_version  = '0.1.0'
    tool_versions_json = '{"esm":"3.2.1","foldseek":"9.427df8a","signalp":"6.0","deeptmhmm":"1.0.24","saprot":"1.0"}'

    // --- reference data (on met) ---
    ref_emb_dir       = "${projectDir}/assets/ref"          // reference_2024.esmc.shard*.npz
    ref_saprot_dir    = "${projectDir}/assets/ref"          // reference_2024.saprot.*
    eval_labels       = "${projectDir}/assets/ref/eval_labels.tsv"
    // Data assets: each default is overridable via -params-file / --<param>, OR
    // by exporting the matching env var (so the same config works on any machine).
    dbcan_db          = System.getenv('DBCAN_DB')       ?: '/array1/xinpeng/dbcan_db'          // run_dbcan V5 database
    pfam_hmm          = System.getenv('PFAM_HMM')       ?: '/array1/xinpeng/pfam/Pfam-A.hmm'   // §2.5 hmmscan domains
    struct_topk       = 10                                       // §2.6 top-K structure hits
    cazyme3d_db       = System.getenv('CAZYME3D_DB')     ?: '/array1/xinpeng/dbcan4-advanced/cazyme3d/db'
    cazyme3d_labels   = System.getenv('CAZYME3D_LABELS') ?: '/array1/xinpeng/dbcan4-advanced/cazyme3d/labels.tsv'

    // --- §2.10 InterProScan / GO ---
    // Real InterProScan is optional (tens of GB). If interproscan_sh is unset or
    // not executable, the pipeline derives GO + InterPro from the Pfam domains via
    // the bundled pfam2go map (offline). See modules/interproscan.nf.
    interproscan_sh   = System.getenv('INTERPROSCAN_SH') ?: null
    pfam2go           = "${projectDir}/assets/mappings/pfam2go.txt"
    pfam2interpro     = System.getenv('PFAM2INTERPRO')   ?: null   // optional PF->IPR TSV to fill the InterPro accession column

    // --- method params ---
    esmc_model        = 'esmc_600m'
    knn_k             = 15
    struct_max        = 200                        // cap folded proteins (bounded subset)
    foldseek_evalue   = '1e-3'
    fusion_weights    = '{}'                        // JSON override; else DEFAULT_WEIGHTS
    fusion_min_conf   = 0.0

    // --- conda envs / tool venvs (met defaults; override via env var or --<param>) ---
    esmc_env          = System.getenv('ESMC_ENV')      ?: '/array1/xinpeng/dbcan4-advanced/venv'
    dbcan_env         = System.getenv('DBCAN_ENV')     ?: '/array1/xinpeng/dbcan4-advanced/venv'  // run_dbcan V5
    clean_env         = System.getenv('CLEAN_ENV')     ?: '/array1/xinpeng/scratch/CLEAN'        // CLEAN EC predictor
    esmfold_env       = System.getenv('ESMFOLD_ENV')   ?: '/home/xinpeng/anaconda3/envs/esmfold2'
    foldseek_env      = System.getenv('FOLDSEEK_ENV')  ?: '/array1/xinpeng/dbcan4-advanced/venv'  // foldseek at /usr/local/bin
    saprot_env        = System.getenv('SAPROT_ENV')    ?: '/array1/xinpeng/dbcan4-advanced/venv_saprot'
    signalp_env       = System.getenv('SIGNALP_ENV')   ?: '/array1/xinpeng/dbcan4-advanced/venv_signalp'
    // DeepTMHMM runs via pybiolib -> BioLib cloud. The biolib-capable venv is at
    // scratch/venv_biolib (verified: biolib 1.4.262; this is the venv the real
    // DeepTMHMM runs used). Real runs shell to the `biolib` console script
    // (`biolib run ...`) — note `python -m biolib` does NOT work (no __main__).
    deeptmhmm_env     = System.getenv('DEEPTMHMM_ENV') ?: '/array1/xinpeng/scratch/venv_biolib'
    biolib_bin        = System.getenv('BIOLIB_BIN')     ?: "${params.deeptmhmm_env}/bin/biolib"
    fusion_env        = null                        // pure-stdlib; base python
}

// bin/ scripts + prototype scripts on PATH inside every task
env {
    PYTHONUNBUFFERED = '1'
}

process {
    // make nf/bin/ and the repo scripts/ callable from process scripts
    beforeScript = "export PATH=${projectDir}/bin:${projectDir}/../scripts:\$PATH"

    withLabel: gpu { cpus = 8;  memory = '32 GB'; accelerator = 1 }
    withLabel: cpu { cpus = 4;  memory = '16 GB' }
}

profiles {
    // Prove the DAG + output contract with zero GPU/tools (CI, laptops).
    // Use together with the `-stub-run` CLI flag. Relaxes resources (no GPU) so
    // every process schedules on a plain machine.
    stub {
        process.beforeScript = "export PATH=${projectDir}/bin:${projectDir}/../scripts:\$PATH"
        process.cpus = 1
        process.memory = '2 GB'
        params.struct_max = 50
    }
    // Real execution on met (no scheduler — jobs run directly; conda envs).
    met {
        conda.enabled = true
        conda.useMamba = false
        process.executor = 'local'
        process { withLabel: gpu { cpus = 8; memory = '48 GB' } }
        // met has 8× A5500; local executor + accelerator hint suffices (no SLURM).
    }
    conda  { conda.enabled = true }
    docker { docker.enabled = true }
    singularity { singularity.enabled = true; singularity.autoMounts = true }
}

// Reproducibility: emit a run report + DAG so every run is auditable.
// (timestamp inlined — Nextflow config disallows top-level `def` mixed with blocks)
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline-${new java.text.SimpleDateFormat('yyyyMMdd-HHmmss').format(new Date())}.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report-${new java.text.SimpleDateFormat('yyyyMMdd-HHmmss').format(new Date())}.html"; overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag-${new java.text.SimpleDateFormat('yyyyMMdd-HHmmss').format(new Date())}.mmd"; overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace-${new java.text.SimpleDateFormat('yyyyMMdd-HHmmss').format(new Date())}.txt"; overwrite = true }
