# Large data & model weights — never committed
*.faa
*.fasta
*.fa
*.pdb
*.cif
*.h5
*.hdf5
*.npy
*.npz
*.pt
*.pth
*.ckpt
*.dmnd
*.hmm
*.index
*.faiss
data/
weights/
models/
structures/
embeddings/
*.tsv.gz

# but DO keep small manifests / metric tables committed:
!benchmarks/*.tsv
!docs/**/*.tsv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env

# OS / editor
.DS_Store
.ipynb_checkpoints/
*.swp

# keep small example FASTAs (override the *.faa ignore above)
!examples/*.faa
real3_workup/
esmfold_out/
ui_chrome/
ui_struct/
results/
*.db

# MkDocs local build output
site/

# Prototype interactive HTML explorers — large (~6MB each), regenerable via prototypes/viz/build_visualizations.py
prototypes/outputs/viz/*.html

# raw single-mode structure renders (regenerable via render_structure_views.py; composite panel is committed)
examples/267317_comprehensive/view_*.png

# ---------------------------------------------------------------------------
# Re-includes MUST come last (gitignore is last-match-wins, and the generic
# `results/` / `*.faa` rules above would otherwise drop these committed assets).
# ---------------------------------------------------------------------------
# Vendored BioForge web-layer test fixtures (small; needed by `pytest`). The
# `results/` subdir must be re-included explicitly — git won't re-include files
# under an already-excluded parent directory.
!sample_data/
!sample_data/**
!sample_data/results/
!sample_data/results/**
# Vendored GO/InterPro mapping for the offline Pfam->GO fallback (nf/assets/mappings/pfam2go.txt):
!nf/assets/mappings/
!nf/assets/mappings/**
